# ─── Sanity (CMS / Database) ──────────────────────────────────────────────────
# 1. Create a project at https://sanity.io
# 2. Run: npx sanity init  (or use the Sanity dashboard)
# 3. Get your project ID from https://www.sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=

# 4. Create an API token with "Editor" permissions at:
#    https://www.sanity.io/manage → your project → API → Tokens
#    ⚠️  This token is SERVER-ONLY — never prefix with NEXT_PUBLIC_
SANITY_API_TOKEN=

# ─── Resend (Email — Phase 2) ──────────────────────────────────────────────────
# https://resend.com — uncomment in API routes when ready
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=no-reply@mincpay.co.za
# RESEND_INTERNAL_EMAIL=hello@mincpay.co.za

# ─── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://mincpay.com
NEXT_PUBLIC_WHATSAPP_NUMBER=
